# ============================================================
#  Nexus Bridge — variáveis de ambiente
#  Copie para .env (NUNCA versione o .env com valores reais).
#  No Render, defina cada uma em Environment.
# ============================================================

# Porta do servidor (o Render injeta PORT automaticamente).
PORT=8080

# Ambiente (development | production). Em production o log fica enxuto.
NODE_ENV=development

# Origens permitidas para CORS (browsers). Separadas por vírgula.
# O painel é same-origin (/panel) e NÃO precisa estar aqui.
# Server-to-server (ex.: o proxy serverless do CRM) também não precisa.
ALLOWED_ORIGINS=https://www.nexusholding.xyz,https://nexusholding.vercel.app

# Limites de requisições (rate limit).
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
# Teto extra, mais agressivo, só para ESCRITAS na Data API.
RATE_LIMIT_DATA_WRITE_MAX=30

# ---- Chaves de ENTRADA dos apps (x-api-key) ----
# Gere valores fortes e únicos: `openssl rand -hex 32`. Prefixo sugerido nxb_.
KEY_CRM=nxb_troque_esta_chave_do_crm
KEY_MIDIA=nxb_troque_esta_chave_da_midia

# ---- Proxy app->app (destinos roteados) ----
# Mídia (Nexus Digital 90) — backend no Render.
MIDIA_URL=https://nexus-midia-api.onrender.com
MIDIA_UPSTREAM_KEY=nxs_troque_esta_chave_upstream_da_midia
# CRM — só quando expuser backend HTTP para a Bridge rotear.
# CRM_URL=
# CRM_UPSTREAM_KEY=

# ============================================================
#  Data API central (Firestore + Supabase)
# ============================================================

# Service accounts dos projetos Firebase, em BASE64 do JSON completo.
# Gere com:  base64 -w0 serviceAccount.json   (ou no PowerShell:
#   [Convert]::ToBase64String([IO.File]::ReadAllBytes("serviceAccount.json")))
FIREBASE_SA_GARDEN_B64=
FIREBASE_SA_POSTFLOW_B64=

# Supabase (Postgres + Storage). A SERVICE ROLE tem poder total —
# por isso toda chamada passa pelo canAccess() por app.
SUPABASE_URL=https://scqjsygyuuvlqpzezyhg.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=nexus-media

# Tetos da Data API.
DATA_MAX_LIMIT=200
DATA_UPLOAD_MAX=26214400

# ============================================================
#  Painel / login Firebase (garden-backup)
# ============================================================
# Allowlist de e-mails que podem acessar o painel (vírgula).
ADMIN_EMAILS=vinicius@nexus.com,perdibitcoin@gmail.com
# Permite ESCRITA de dados pelo admin do painel (default: false).
ADMIN_WRITE=false
# Verifica revogação de token a cada request (round-trip; default false).
FIREBASE_CHECK_REVOKED=false

# ============================================================
#  Telemetria
# ============================================================
TELEMETRY_BUFFER=200
SSE_MAX_CLIENTS=50
